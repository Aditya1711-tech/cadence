# Copy to deploy/.env and fill in. Consumed by deploy/docker-compose.yml.
DATABASE_NAME=cadence
DATABASE_USER=cadence
DATABASE_PASSWORD=cadence

# 32+ byte random; the backend refuses to start if shorter.
# Generate: openssl rand -base64 48
JWT_SIGNING_SECRET=change-me-to-a-32-byte-minimum-secret-value
JWT_TTL_MINUTES=60

DEFAULT_ORG_PRIVACY=categories_only
APP_PUBLIC_BASE_URL=http://localhost:3000

# Email: leave SMTP_HOST empty in dev (reset/enroll links are logged instead).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@cadence.local
