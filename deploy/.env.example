# Copy to deploy/.env and fill in. Consumed by deploy/docker-compose.yml.
DATABASE_NAME=cadence
DATABASE_USER=cadence
DATABASE_PASSWORD=cadence

# 32+ byte random; the backend refuses to start if shorter.
# Generate: openssl rand -base64 48
JWT_SIGNING_SECRET=change-me-to-a-32-byte-minimum-secret-value
JWT_TTL_MINUTES=60

DEFAULT_ORG_PRIVACY=categories_only
APP_PUBLIC_BASE_URL=http://localhost:3000

# Email: leave SMTP_HOST empty in dev (reset/enroll links are logged instead).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@cadence.local

# GitHub App (P2-D). Webhook URL = <APP_PUBLIC_BASE_URL>/api/v1/github/webhook.
# GITHUB_APP_ID + GITHUB_APP_PRIVATE_KEY are only needed for full_diff enrichment.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_DEFAULT_MODE=commit_messages_only

# Categorisation worker (P2-F) — OFF unless enabled; needs ANTHROPIC_API_KEY + Redis.
CADENCE_CATEGORIZE_ENABLED=false
ANTHROPIC_API_KEY=
CADENCE_CATEGORIZE_MODEL=claude-haiku-4-5
CADENCE_CATEGORIZE_DAILY_TOKEN_CAP=0
