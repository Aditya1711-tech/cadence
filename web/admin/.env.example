# Cadence org admin dashboard (P2-E) — runtime env.
#
# The admin app talks to the Spring backend SERVER-SIDE through its own BFF
# route handlers (app/api/*). The browser only ever calls same-origin Next
# routes, so no backend CORS config is needed and the access/refresh tokens stay
# in an httpOnly cookie (unreadable by JS), never in the browser bundle.
#
# NOTE: this is a RUNTIME var read on the server, NOT NEXT_PUBLIC_* (which Next
# inlines into the browser bundle at build time and can't be set per deploy).
CADENCE_API_BASE=http://localhost:8080

# Name of the httpOnly session cookie that holds the token pair + identity.
# Override only if it collides with another app on the same host.
# CADENCE_ADMIN_COOKIE=cadence_admin_session

# Set to "true" only behind HTTPS so the session cookie is marked Secure.
# Leave unset/false for local http://localhost development.
# CADENCE_COOKIE_SECURE=false
