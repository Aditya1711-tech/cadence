# Cadence dashboard (Phase 1, local-only) — runtime configuration.
#
# These are read SERVER-SIDE at runtime (the dashboard proxies the daemon, so
# the browser never needs the daemon URL). Do NOT use NEXT_PUBLIC_* for these —
# Next inlines NEXT_PUBLIC_* at build time, so they can't be changed per machine.

# Base URL of the local Cadence daemon. Defaults to the daemon's default port
# (P1-A cmd/cadence-agent: 47821) when unset.
CADENCE_AGENT_BASE=http://127.0.0.1:47821

# Set to 1 to render a synthetic day from fixtures instead of the live daemon
# (useful for UI dev without running the agent).
CADENCE_USE_MOCK=0
