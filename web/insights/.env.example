# Cadence insights — NL query UI (P3-C) — runtime env.
#
# Like the admin app, this talks to the Spring backend SERVER-SIDE through its
# own BFF route handlers (app/api/*). The browser only calls same-origin Next
# routes, so the access/refresh tokens stay in an httpOnly cookie (unreadable by
# JS) and no backend CORS config is needed.
#
# RUNTIME var read on the server — NOT NEXT_PUBLIC_* (which Next inlines into the
# browser bundle at build time and can't be set per deploy).
CADENCE_API_BASE=http://localhost:8080

# Name of the httpOnly session cookie. Distinct from the admin app's so the two
# can be served on the same host without collision.
# CADENCE_INSIGHTS_COOKIE=cadence_insights_session

# Set to "true" only behind HTTPS so the session cookie is marked Secure.
# CADENCE_COOKIE_SECURE=false
